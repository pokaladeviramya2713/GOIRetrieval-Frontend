<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Header: Title and Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_document_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-bold"
                android:text="National Education Policy 2020"
                android:textColor="@color/navy_home"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/grey_text" />
        </LinearLayout>

        <!-- Document Info: Type and Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_document_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Policy"
                android:textColor="#546E7A"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="•"
                android:textColor="@color/grey_text"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_document_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="2023-10-15"
                android:textColor="@color/grey_text"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Keyword Tags -->
        <LinearLayout
            android:id="@+id/ll_keyword_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <!-- Tags will be dynamically added here, but we can put some dummies for layout -->
            <TextView
                android:id="@+id/tv_tag1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_pill"
                android:backgroundTint="#F0F4FF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="#funding eligibility"
                android:textColor="#1A237E"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_tag2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tag_pill"
                android:backgroundTint="#F0F4FF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="#accreditation"
                android:textColor="#1A237E"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_tag3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tag_pill"
                android:backgroundTint="#F0F4FF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="#AICTE"
                android:textColor="#1A237E"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Compliance Score Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Compliance Score"
                android:textColor="@color/grey_text"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_compliance_score_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:text="92 %"
                android:textColor="#00C853"
                android:textSize="16sp" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_compliance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:trackThickness="6dp"
            app:trackCornerRadius="3dp"
            app:trackColor="#F5F5F5"
            app:indicatorColor="#00C853"
            android:progress="92" />

        <TextView
            android:id="@+id/tv_compliance_level"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:text="High Compliance"
            android:textColor="#00C853"
            android:textSize="10sp" />

        <!-- AI Summary Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_tag_pill"
            android:backgroundTint="#F5F7F9"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_ai_stars_white"
                    app:tint="@color/navy_home" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="AI Summary"
                    android:textColor="@color/navy_home"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_ai_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="High alignment with funding eligibility criteria."
                android:textColor="#455A64"
                android:textSize="11sp"
                android:lineSpacingExtra="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/tv_exact_reference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Reference: &quot;Funding eligibility subject to NAAC Grade A++&quot;"
                android:textColor="#1B5E20"
                android:textSize="10sp"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:weightSum="1">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_document"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:backgroundTint="#1A348A"
                android:fontFamily="sans-serif-medium"
                android:text="Open Document"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
