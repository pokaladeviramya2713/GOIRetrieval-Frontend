<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_date_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:text="Today"
            android:textColor="@color/grey_text"
            android:textSize="12sp"
            android:fontFamily="sans-serif-bold"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/iv_activity_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_stat_icon_blue"
                android:padding="8dp"
                android:src="@drawable/ic_search_nav"
                app:tint="#1D4ED8" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_activity_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Searched for 'NEP 2020'"
                    android:textColor="@color/navy_home"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"/>

                <TextView
                    android:id="@+id/tv_activity_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="10:30 AM"
                    android:textColor="@color/grey_text"
                    android:textSize="10sp"/>
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right_grey"
                app:tint="@color/grey_text"
                android:alpha="0.5"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
