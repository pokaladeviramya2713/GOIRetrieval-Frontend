<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingBottom="24dp"
    android:background="#f8f9fa">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 1. Top Branding Header (Compact) -->
        <LinearLayout 
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="4dp"
            android:background="@android:color/white">

            <LinearLayout 
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@android:color/white">
                    <ImageView 
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/app_logo_premium"
                        android:scaleType="centerInside"
                        android:padding="0dp" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout 
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView 
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GOI Retrieval"
                        android:textColor="@color/navy_home"
                        android:fontFamily="sans-serif-black"
                        android:textSize="16sp" />
                    <TextView 
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ministry of Education"
                        android:textColor="@color/grey_text"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <RelativeLayout 
                android:id="@+id/rl_notification_bell"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_profile_circle"
                android:backgroundTint="@color/white"
                android:clickable="true"
                android:focusable="true">
                <ImageView 
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/grey_text" />
                <View 
                    android:id="@+id/view_notification_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/dot_red"
                    android:visibility="gone" />
            </RelativeLayout>
        </LinearLayout>

        <!-- White wrapper for the top upload area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"
            android:elevation="2dp">

            <!-- Dashed Upload Area -->
            <LinearLayout
                android:id="@+id/ll_upload_area"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_upload_circle"
                    app:tint="#21336a" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Drop your messy files here"
                    android:textColor="@color/navy_home"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Multiple CSV, PDF or JSON files (Max 1GB)"
                    android:textColor="@color/grey_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_selected_file"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0 files selected"
                    android:textColor="#21336a"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="visible" />

            </LinearLayout>
        </LinearLayout>

        <!-- Audit Mode Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_light_blue"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:text="Select Intelligence Mode"
                android:textColor="@color/navy_home"
                android:textSize="16sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="16dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Mode 1: Scenario -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_mode_scenario"
                        android:layout_width="150dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@android:color/white"
                        app:strokeWidth="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:id="@+id/iv_mode_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_ai_stars_white"
                                app:tint="#21336a"/>
                            <TextView
                                android:id="@+id/tv_mode_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Scenario\nSimulator"
                                android:textAlignment="center"
                                android:textColor="#21336a"
                                android:fontFamily="sans-serif-bold"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mode 2: Conflict -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_mode_conflict"
                        android:layout_width="150dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeColor="#f0f0f0"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:id="@+id/iv_mode_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_search_nav"
                                app:tint="@color/grey_text"/>
                            <TextView
                                android:id="@+id/tv_mode_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Conflict\nDetector"
                                android:textAlignment="center"
                                android:textColor="@color/grey_text"
                                android:fontFamily="sans-serif-bold"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mode 3: Gap -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_mode_gap"
                        android:layout_width="150dp"
                        android:layout_height="120dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeColor="#f0f0f0"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:id="@+id/iv_mode_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_documents"
                                app:tint="@color/grey_text"/>
                            <TextView
                                android:id="@+id/tv_mode_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Gap\nAnalysis"
                                android:textAlignment="center"
                                android:textColor="@color/grey_text"
                                android:fontFamily="sans-serif-bold"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Remaining Form fields in standard background -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Source Truth Configuration -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-bold"
                        android:text="Audit Parameters"
                        android:textColor="@color/navy_home"
                        android:textSize="16sp" />
                    
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="#f0f0f0" />

                    <!-- Source URL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Context / Official Link (Optional)"
                        android:textColor="@color/navy_home"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_source_url"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Provide a URL to check latest circulars"
                        android:inputType="textUri"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/navy_home"
                        android:textColorHint="#bdbdbd"
                        android:textSize="14sp" />

                    <!-- Questions / Context -->
                    <LinearLayout
                        android:id="@+id/ll_questions_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Specific Compliance Questions"
                            android:textColor="@color/navy_home"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/et_keywords"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="top"
                            android:hint="What should the AI check for in your files? (e.g., Eligibility, Timeline matches, Funding rules)"
                            android:inputType="textMultiLine"
                            android:minHeight="80dp"
                            android:padding="12dp"
                            android:textColor="@color/navy_home"
                            android:textColorHint="#bdbdbd"
                            android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ai_analyze"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#21336a"
                android:fontFamily="sans-serif-bold"
                android:text="Start AI Audit Analysis"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_ai_stars_white"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@android:color/white" />

            <!-- Secondary Option: Chat -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:text="OR"
                android:textColor="@color/grey_text"
                android:textSize="12sp"
                android:fontFamily="sans-serif-bold"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ask_ai"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:fontFamily="sans-serif-medium"
                android:text="Ask AI Direct Questions"
                android:textAllCaps="false"
                android:textColor="#21336a"
                android:textSize="14sp"
                app:cornerRadius="16dp"
                app:strokeColor="#21336a"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_ai_stars_white"
                app:iconTint="#21336a" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
