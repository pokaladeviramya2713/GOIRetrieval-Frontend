<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_grey_bg">

    <!-- Fragment Container -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav" />

    <!-- Bottom Navigation (Custom Layout preserved for UI consistency) -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home_nav"
                app:tint="@color/navy_home" />
            <TextView 
                android:id="@+id/tv_nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/navy_home"
                android:fontFamily="sans-serif-bold"
                android:textSize="10sp" />
            <View 
                android:id="@+id/dot_nav_home"
                android:layout_width="6dp" android:layout_height="6dp" 
                android:layout_marginTop="6dp"
                android:background="@drawable/nav_active_dot"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_search"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search_nav"
                app:tint="@color/grey_text" />
            <TextView 
                android:id="@+id/tv_nav_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textColor="@color/grey_text"
                android:textSize="10sp" />
            <View 
                android:id="@+id/dot_nav_search"
                android:layout_width="6dp" android:layout_height="6dp" 
                android:layout_marginTop="6dp"
                android:visibility="invisible"
                android:background="@drawable/nav_active_dot"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_docs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_docs"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_docs_nav"
                app:tint="@color/grey_text" />
            <TextView 
                android:id="@+id/tv_nav_docs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Docs"
                android:textColor="@color/grey_text"
                android:textSize="10sp" />
            <View 
                android:id="@+id/dot_nav_docs"
                android:layout_width="6dp" android:layout_height="6dp" 
                android:layout_marginTop="6dp"
                android:visibility="invisible"
                android:background="@drawable/nav_active_dot"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_ai_assist"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_ai"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ai_assist_nav"
                app:tint="@color/grey_text" />
            <TextView 
                android:id="@+id/tv_nav_ai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Assist"
                android:textColor="@color/grey_text"
                android:textSize="10sp" />
            <View 
                android:id="@+id/dot_nav_ai"
                android:layout_width="6dp" android:layout_height="6dp" 
                android:layout_marginTop="6dp"
                android:visibility="invisible"
                android:background="@drawable/nav_active_dot"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_profile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile_nav"
                app:tint="@color/grey_text" />
            <TextView 
                android:id="@+id/tv_nav_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="@color/grey_text"
                android:textSize="10sp" />
            <View 
                android:id="@+id/dot_nav_profile"
                android:layout_width="6dp" android:layout_height="6dp" 
                android:layout_marginTop="6dp"
                android:visibility="invisible"
                android:background="@drawable/nav_active_dot"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
