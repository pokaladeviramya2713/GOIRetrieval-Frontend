<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="180dp"
        android:gravity="top|center_horizontal"
        android:orientation="vertical"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_stat_icon_lavender"
                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_documents"
                    app:tint="@color/navy_home" />
            </RelativeLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/tv_report_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="2"
            android:text="AISHE 2023-24 Full Report"
            android:textColor="@color/navy_home"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_report_dept"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ministry of Education"
            android:textColor="@color/grey_text"
            android:textSize="10sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_report_delete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_profile_circle"
                android:backgroundTint="#FFEBEE"
                android:padding="8dp"
                android:src="@drawable/ic_delete"
                app:tint="#C62828" />

            <ImageView
                android:id="@+id/btn_report_download"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_profile_circle"
                android:backgroundTint="#F5F5F5"
                android:padding="8dp"
                android:src="@drawable/ic_download"
                app:tint="@color/navy_home" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
