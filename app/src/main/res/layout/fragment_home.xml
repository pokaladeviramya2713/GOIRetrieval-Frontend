<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_grey_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Welcome Message & Stats Container (Rounded Blue) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_rounded"
            android:paddingBottom="24dp">

            <!-- Top Header Action Bar (Compact) -->
            <LinearLayout 
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingHorizontal="20dp">

                <!-- Branding Left -->
                <LinearLayout 
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="@android:color/white">
                        <ImageView 
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/app_logo_premium"
                            android:scaleType="centerInside"
                            android:padding="0dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout 
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView 
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GOI Retrieval"
                            android:textColor="@color/navy_home"
                            android:fontFamily="sans-serif-black"
                            android:textSize="16sp"
                            android:lineHeight="18dp" />
                        <TextView 
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ministry of Education"
                            android:textColor="@color/grey_text"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Actions Right -->
                <LinearLayout 
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    
                    <RelativeLayout 
                        android:id="@+id/rl_notification_bell"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_profile_circle"
                        android:backgroundTint="@color/white"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">
                        <ImageView 
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerInParent="true"
                            android:src="@drawable/ic_notification"
                            app:tint="@color/grey_text" />
                        <View 
                            android:id="@+id/view_notification_dot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/dot_red"
                            android:visibility="gone" />
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="32dp">

                <TextView 
                    android:id="@+id/tv_current_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thursday, 12 February"
                    android:textColor="@color/grey_text"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:id="@+id/ll_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView 
                            android:id="@+id/hello_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hello, "
                            android:textColor="@color/navy_home"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView 
                            android:id="@+id/tv_user_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admin Sharma"
                            android:textColor="@color/navy_home"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_profile_circle"
                        android:backgroundTint="#E8F5E9"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_green" />

                        <TextView 
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="ONLINE"
                            android:textColor="@color/online_green"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- Dashboard Stats Section -->
            <LinearLayout
                android:id="@+id/section_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Stats Horizontal Scroll -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="10dp"
                    android:paddingTop="24dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Documents Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="10dp"
                            app:cardBackgroundColor="@android:color/white"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <ImageView
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        android:background="@drawable/bg_stat_icon_lavender"
                                        android:padding="8dp"
                                        android:src="@drawable/ic_documents"
                                        app:tint="@color/navy_home" />
                                    <TextView 
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_alignParentEnd="true"
                                        android:background="@drawable/bg_pct_badge"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="2dp"
                                        android:text="↗ 12%"
                                        android:textColor="#2E7D32"
                                        android:textSize="10sp"
                                        android:fontFamily="sans-serif-black" />
                                </RelativeLayout>

                                <TextView 
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="16dp"
                                    android:text="Documents"
                                    android:textColor="@color/grey_text"
                                    android:textSize="12sp" />

                                <TextView 
                                    android:id="@+id/tv_docs_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="-"
                                    android:textColor="@color/navy_home"
                                    android:textSize="20sp"
                                    android:fontFamily="sans-serif-black" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- AI Queries Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="10dp"
                            app:cardBackgroundColor="@android:color/white"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <ImageView
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        android:background="@drawable/bg_stat_icon_purple"
                                        android:padding="8dp"
                                        android:src="@drawable/ic_ai_queries"
                                        app:tint="@color/navy_home" />
                                    <TextView 
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_alignParentEnd="true"
                                        android:background="@drawable/bg_pct_badge"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="2dp"
                                        android:text="↗ 8%"
                                        android:textColor="#2E7D32"
                                        android:textSize="10sp"
                                        android:fontFamily="sans-serif-black" />
                                </RelativeLayout>

                                <TextView 
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="16dp"
                                    android:text="AI Queries"
                                    android:textColor="@color/grey_text"
                                    android:textSize="12sp" />

                                <TextView 
                                    android:id="@+id/tv_ai_queries_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="3.8k"
                                    android:textColor="@color/navy_home"
                                    android:textSize="20sp"
                                    android:fontFamily="sans-serif-black" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Users Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="10dp"
                            app:cardBackgroundColor="@android:color/white"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <ImageView
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        android:background="@drawable/bg_stat_icon_orange"
                                        android:padding="8dp"
                                        android:src="@drawable/ic_users_home"
                                        app:tint="@color/navy_home" />
                                </RelativeLayout>

                                <TextView 
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="16dp"
                                    android:text="Users"
                                    android:textColor="@color/grey_text"
                                    android:textSize="12sp" />

                                <TextView 
                                    android:id="@+id/tv_users_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="-"
                                    android:textColor="@color/navy_home"
                                    android:textSize="20sp"
                                    android:fontFamily="sans-serif-black" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>

        <!-- Lower Section (Clean Grey) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/light_grey_bg"
            android:paddingBottom="24dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Retrieval Trends -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/section_trends_chart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                             <View
                                 android:layout_width="4dp"
                                 android:layout_height="16dp"
                                 android:background="#EF6C00"/>
                            <TextView 
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Retrieval Trends"
                                android:textColor="@color/navy_home"
                                android:fontFamily="sans-serif-black"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <TextView 
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/bg_profile_circle"
                            android:backgroundTint="#F5F5F5"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="This Week ▾"
                            android:textColor="@color/grey_text"
                            android:textSize="12sp" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/trends_graph_container"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="16dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <com.simats.goiretrieval.TrendGraphView
                            android:id="@+id/trend_graph_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.1"
                            android:background="@drawable/bg_graph_gradient"/>

                        <include layout="@layout/layout_graph_flag" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center">
                        <TextView 
                            android:id="@+id/tv_day_0"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Mon"
                            android:textColor="@color/grey_text"
                            android:textSize="10sp"
                            tools:text="Mon" />

                        <TextView 
                            android:id="@+id/tv_day_1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Tue"
                            android:textColor="@color/grey_text"
                            android:textSize="10sp"
                            tools:text="Tue" />

                        <TextView 
                            android:id="@+id/tv_day_2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Wed"
                            android:textColor="@color/grey_text"
                            android:textSize="10sp"
                            tools:text="Wed" />

                        <TextView 
                            android:id="@+id/tv_day_3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Thu"
                            android:textColor="@color/grey_text"
                            android:textSize="10sp"
                            tools:text="Thu" />

                        <TextView 
                            android:id="@+id/tv_day_4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Fri"
                            android:textColor="@color/grey_text"
                            android:textSize="10sp"
                            tools:text="Fri" />

                        <TextView 
                            android:id="@+id/tv_day_5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Sat"
                            android:textColor="@color/grey_text"
                            android:textSize="10sp"
                            tools:text="Sat" />

                        <TextView 
                            android:id="@+id/tv_day_6"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Sun"
                            android:textColor="@color/grey_text"
                            android:textSize="10sp"
                            tools:text="Sun" />
                    </LinearLayout>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Grid -->
            <TextView 
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:text="Quick Actions"
                android:textColor="@color/navy_home"
                android:fontFamily="sans-serif-black"
                android:textSize="18sp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="12dp"
                android:columnCount="2">

                <!-- Search -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_search_docs"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_action_blue"
                            android:padding="12dp"
                            android:src="@drawable/ic_search_nav"
                            app:tint="@color/navy_home" />
                        <TextView 
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Search Docs"
                            android:textColor="@color/navy_home"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Browse -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_browse_docs"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_action_lavender"
                            android:padding="12dp"
                            android:src="@drawable/ic_browse_docs"
                            app:tint="@color/navy_home" />
                        <TextView 
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Browse Docs"
                            android:textColor="@color/navy_home"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- AI -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_ai_assist"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_action_orange"
                            android:padding="12dp"
                            android:src="@drawable/ic_ai_assist_nav"
                            android:layout_marginBottom="8dp"
                            app:tint="@color/navy_home" />
                        <TextView 
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="AI Assist"
                            android:textColor="@color/navy_home"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <!-- Reports -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_reports"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_action_green"
                            android:padding="12dp"
                            android:src="@drawable/ic_reports_home"
                            app:tint="@color/navy_home" />
                        <TextView 
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Reports"
                            android:textColor="@color/navy_home"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Recent Activity Section -->
            <LinearLayout
                android:id="@+id/section_recent_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp">
                <TextView 
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Activity"
                    android:textColor="@color/navy_home"
                    android:fontFamily="sans-serif-black"
                    android:textSize="18sp" />
                <TextView 
                    android:id="@+id/tv_view_all_activity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="VIEW ALL"
                    android:textColor="@color/navy_home"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="12sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_recent_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_home_activity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
</androidx.core.widget.NestedScrollView>
